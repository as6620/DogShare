<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="10dp"
    android:background="#FFFFFF"
    tools:context=".Fragments.WalkScheduleFragment">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="10dp"
        android:gravity="center"
        android:text="Walk schedule"
        android:textColor="#000000"
        android:textSize="30sp"
        android:textStyle="bold" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:orientation="horizontal"
            android:background="#D3D3D3">
            <TextView android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center" android:text="" android:background="@drawable/table_border" />
            <TextView android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1.5" android:gravity="center" android:text="Morning 7:00" android:textSize="12sp" android:textStyle="bold" android:background="@drawable/table_border" />
            <TextView android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1.5" android:gravity="center" android:text="Afternoon 14:00" android:textSize="12sp" android:textStyle="bold" android:background="@drawable/table_border" />
            <TextView android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1.5" android:gravity="center" android:text="Evening 20:00" android:textSize="12sp" android:textStyle="bold" android:background="@drawable/table_border" />
        </LinearLayout>

        <LinearLayout android:layout_width="match_parent" android:layout_height="45dp" android:orientation="horizontal">
            <TextView android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center" android:text="Sunday" android:background="@drawable/table_border" />
            <TextView android:id="@+id/tvSunMorn" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1.5" android:gravity="center" android:background="@drawable/table_border" />
            <TextView android:id="@+id/tvSunAfter" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1.5" android:gravity="center" android:background="@drawable/table_border" />
            <TextView android:id="@+id/tvSunEve" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1.5" android:gravity="center" android:background="@drawable/table_border" />
        </LinearLayout>

        <LinearLayout android:layout_width="match_parent" android:layout_height="45dp" android:orientation="horizontal">
            <TextView android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center" android:text="Monday" android:background="@drawable/table_border" />
            <TextView android:id="@+id/tvMonMorn" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1.5" android:gravity="center" android:background="@drawable/table_border" />
            <TextView android:id="@+id/tvMonAfter" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1.5" android:gravity="center" android:background="@drawable/table_border" />
            <TextView android:id="@+id/tvMonEve" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1.5" android:gravity="center" android:background="@drawable/table_border" />
        </LinearLayout>

        <LinearLayout android:layout_width="match_parent" android:layout_height="45dp" android:orientation="horizontal">
            <TextView android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center" android:text="Tuesday" android:background="@drawable/table_border" />
            <TextView android:id="@+id/tvTueMorn" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1.5" android:gravity="center" android:background="@drawable/table_border" />
            <TextView android:id="@+id/tvTueAfter" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1.5" android:gravity="center" android:background="@drawable/table_border" />
            <TextView android:id="@+id/tvTueEve" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1.5" android:gravity="center" android:background="@drawable/table_border" />
        </LinearLayout>

        <LinearLayout android:layout_width="match_parent" android:layout_height="45dp" android:orientation="horizontal">
            <TextView android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center" android:text="Wednesday" android:textSize="12sp" android:background="@drawable/table_border" />
            <TextView android:id="@+id/tvWedMorn" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1.5" android:gravity="center" android:background="@drawable/table_border" />
            <TextView android:id="@+id/tvWedAfter" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1.5" android:gravity="center" android:background="@drawable/table_border" />
            <TextView android:id="@+id/tvWedEve" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1.5" android:gravity="center" android:background="@drawable/table_border" />
        </LinearLayout>

        <LinearLayout android:layout_width="match_parent" android:layout_height="45dp" android:orientation="horizontal">
            <TextView android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center" android:text="Thursday" android:background="@drawable/table_border" />
            <TextView android:id="@+id/tvThuMorn" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1.5" android:gravity="center" android:background="@drawable/table_border" />
            <TextView android:id="@+id/tvThuAfter" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1.5" android:gravity="center" android:background="@drawable/table_border" />
            <TextView android:id="@+id/tvThuEve" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1.5" android:gravity="center" android:background="@drawable/table_border" />
        </LinearLayout>

        <LinearLayout android:layout_width="match_parent" android:layout_height="45dp" android:orientation="horizontal">
            <TextView android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center" android:text="Friday" android:background="@drawable/table_border" />
            <TextView android:id="@+id/tvFriMorn" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1.5" android:gravity="center" android:background="@drawable/table_border" />
            <TextView android:id="@+id/tvFriAfter" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1.5" android:gravity="center" android:background="@drawable/table_border" />
            <TextView android:id="@+id/tvFriEve" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1.5" android:gravity="center" android:background="@drawable/table_border" />
        </LinearLayout>

        <LinearLayout android:layout_width="match_parent" android:layout_height="45dp" android:orientation="horizontal">
            <TextView android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center" android:text="Saturday" android:background="@drawable/table_border" />
            <TextView android:id="@+id/tvSatMorn" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1.5" android:gravity="center" android:background="@drawable/table_border" />
            <TextView android:id="@+id/tvSatAfter" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1.5" android:gravity="center" android:background="@drawable/table_border" />
            <TextView android:id="@+id/tvSatEve" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1.5" android:gravity="center" android:background="@drawable/table_border" />
        </LinearLayout>
    </LinearLayout>

    <Button
        android:id="@+id/btnAskReplacement"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="ask for replacment"
        android:layout_marginTop="20dp" />

    <Button
        android:id="@+id/btnEditParents"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Edit only for parents"
        android:layout_marginTop="5dp" />

</LinearLayout>