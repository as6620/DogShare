<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="8dp"
    android:background="#FFFFFF"
    tools:context=".Fragments.WalkFragment">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="Walk schedule"
        android:textColor="#000000"
        android:textSize="24sp"
        android:textStyle="bold"
        android:layout_marginBottom="4dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="0.85"
        android:orientation="vertical">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:background="#D3D3D3">
            <TextView android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center" android:text="" android:background="@drawable/table_border" />
            <TextView android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1.5" android:gravity="center" android:text="Morning" android:textSize="10sp" android:textStyle="bold" android:background="@drawable/table_border" />
            <TextView android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1.5" android:gravity="center" android:text="Afternoon" android:textSize="10sp" android:textStyle="bold" android:background="@drawable/table_border" />
            <TextView android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1.5" android:gravity="center" android:text="Evening" android:textSize="10sp" android:textStyle="bold" android:background="@drawable/table_border" />
        </LinearLayout>

        <!-- Sunday Row -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:orientation="horizontal">
            <TextView android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center" android:text="Sunday" android:textSize="11sp" android:background="@drawable/table_border" />
            <TextView android:id="@+id/tvSunMorn" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1.5" android:gravity="center" android:textSize="11sp" android:background="@drawable/table_border" />
            <TextView android:id="@+id/tvSunAfter" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1.5" android:gravity="center" android:textSize="11sp" android:background="@drawable/table_border" />
            <TextView android:id="@+id/tvSunEve" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1.5" android:gravity="center" android:textSize="11sp" android:background="@drawable/table_border" />
        </LinearLayout>

        <!-- Monday Row -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:orientation="horizontal">
            <TextView android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center" android:text="Monday" android:textSize="11sp" android:background="@drawable/table_border" />
            <TextView android:id="@+id/tvMonMorn" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1.5" android:gravity="center" android:textSize="11sp" android:background="@drawable/table_border" />
            <TextView android:id="@+id/tvMonAfter" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1.5" android:gravity="center" android:textSize="11sp" android:background="@drawable/table_border" />
            <TextView android:id="@+id/tvMonEve" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1.5" android:gravity="center" android:textSize="11sp" android:background="@drawable/table_border" />
        </LinearLayout>

        <!-- Tuesday Row -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:orientation="horizontal">
            <TextView android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center" android:text="Tuesday" android:textSize="11sp" android:background="@drawable/table_border" />
            <TextView android:id="@+id/tvTueMorn" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1.5" android:gravity="center" android:textSize="11sp" android:background="@drawable/table_border" />
            <TextView android:id="@+id/tvTueAfter" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1.5" android:gravity="center" android:textSize="11sp" android:background="@drawable/table_border" />
            <TextView android:id="@+id/tvTueEve" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1.5" android:gravity="center" android:textSize="11sp" android:background="@drawable/table_border" />
        </LinearLayout>

        <!-- Wednesday Row -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:orientation="horizontal">
            <TextView android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center" android:text="Wednesday" android:textSize="11sp" android:background="@drawable/table_border" />
            <TextView android:id="@+id/tvWedMorn" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1.5" android:gravity="center" android:textSize="11sp" android:background="@drawable/table_border" />
            <TextView android:id="@+id/tvWedAfter" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1.5" android:gravity="center" android:textSize="11sp" android:background="@drawable/table_border" />
            <TextView android:id="@+id/tvWedEve" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1.5" android:gravity="center" android:textSize="11sp" android:background="@drawable/table_border" />
        </LinearLayout>

        <!-- Thursday Row -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:orientation="horizontal">
            <TextView android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center" android:text="Thursday" android:textSize="11sp" android:background="@drawable/table_border" />
            <TextView android:id="@+id/tvThuMorn" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1.5" android:gravity="center" android:textSize="11sp" android:background="@drawable/table_border" />
            <TextView android:id="@+id/tvThuAfter" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1.5" android:gravity="center" android:textSize="11sp" android:background="@drawable/table_border" />
            <TextView android:id="@+id/tvThuEve" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1.5" android:gravity="center" android:textSize="11sp" android:background="@drawable/table_border" />
        </LinearLayout>

        <!-- Friday Row -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:orientation="horizontal">
            <TextView android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center" android:text="Friday" android:textSize="11sp" android:background="@drawable/table_border" />
            <TextView android:id="@+id/tvFriMorn" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1.5" android:gravity="center" android:textSize="11sp" android:background="@drawable/table_border" />
            <TextView android:id="@+id/tvFriAfter" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1.5" android:gravity="center" android:textSize="11sp" android:background="@drawable/table_border" />
            <TextView android:id="@+id/tvFriEve" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1.5" android:gravity="center" android:textSize="11sp" android:background="@drawable/table_border" />
        </LinearLayout>

        <!-- Saturday Row -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:orientation="horizontal">
            <TextView android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center" android:text="Saturday" android:textSize="11sp" android:background="@drawable/table_border" />
            <TextView android:id="@+id/tvSatMorn" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1.5" android:gravity="center" android:textSize="11sp" android:background="@drawable/table_border" />
            <TextView android:id="@+id/tvSatAfter" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1.5" android:gravity="center" android:textSize="11sp" android:background="@drawable/table_border" />
            <TextView android:id="@+id/tvSatEve" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1.5" android:gravity="center" android:textSize="11sp" android:background="@drawable/table_border" />
        </LinearLayout>
    </LinearLayout>

    <!-- Buttons -->
    <Button
        android:id="@+id/btnAskReplacement"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:text="ask for replacment"
        android:textSize="12sp"
        android:layout_marginTop="8dp" />

    <Button
        android:id="@+id/btnEditParents"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:text="Edit only for parents"
        android:textSize="12sp"
        android:layout_marginTop="4dp" />

</LinearLayout>