<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F9FA"
    android:padding="20dp">

    <TextView
        android:id="@+id/tv_greeting"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Hi Username!"
        android:textSize="26sp"
        android:fontFamily="sans-serif-black"
        android:textColor="#2D3436"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/card_dog_info"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        app:cardCornerRadius="24dp"
        app:cardElevation="6dp"
        app:strokeWidth="0dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_greeting">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/iv_dog_image"
                android:layout_width="match_parent"
                android:layout_height="140dp"
                android:scaleType="centerCrop"
                android:src="@drawable/ic_launcher_background" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">

                <TextView
                    android:id="@+id/tv_dog_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Dog Name"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="#2D3436" />

                <TextView
                    android:id="@+id/tv_dog_breed"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Breed Name"
                    android:textSize="13sp"
                    android:textColor="#636E72" />

                <TextView
                    android:id="@+id/tv_dog_details"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Age: 3 | Male"
                    android:textSize="12sp"
                    android:textColor="#6C5CE7"
                    android:textStyle="bold"
                    android:layout_marginTop="2dp" />
            </LinearLayout>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/card_group"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="2dp"
        app:cardBackgroundColor="#F1F2F6"
        app:strokeWidth="0dp"
        app:layout_constraintTop_toBottomOf="@id/card_dog_info"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="10dp"
            android:gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Family Group Code"
                android:textSize="11sp"
                android:textColor="#636E72" />

            <TextView
                android:id="@+id/tv_group_code_value"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="------"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#6C5CE7"
                android:letterSpacing="0.2" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <LinearLayout
        android:id="@+id/stats_layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:orientation="horizontal"
        android:weightSum="3"
        app:layout_constraintTop_toBottomOf="@id/card_group"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Last Fed"
                android:textSize="11sp"
                android:textColor="#636E72"/>
            <TextView
                android:id="@+id/tv_last_fed"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="10:30"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="#2D3436" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Next Walk"
                android:textSize="11sp"
                android:textColor="#636E72"/>
            <TextView
                android:id="@+id/tv_next_walk"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="18:00\n(Idan)"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="#2D3436"
                android:gravity="center" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Next Vet"
                android:textSize="11sp"
                android:textColor="#636E72"/>
            <TextView
                android:id="@+id/tv_next_vet"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="06/07"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="#2D3436" />
        </LinearLayout>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
