<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center_horizontal"
    android:padding="24dp">

    <!-- Title -->
    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Welcome! What would you like to do next?"
        android:textSize="22sp"
        android:textStyle="bold"
        android:gravity="center"
        android:layout_marginBottom="16dp" />

    <!-- Description -->
    <TextView
        android:id="@+id/tvDescription"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="DogCare is a family-based app that helps you organize and share all dog-related tasks in one place. From walking schedules and feeding logs to meeting other dog owners and tracking food supplies – everything your dog needs, managed together."
        android:textSize="16sp"
        android:gravity="center"
        android:layout_marginBottom="20dp" />

    <!-- Notification text -->
    <TextView
        android:id="@+id/tvNotification"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="To keep you updated with reminders for walks, feedings, and other tasks, please allow notification access."
        android:textSize="15sp"
        android:gravity="center"
        android:layout_marginBottom="30dp" />

    <!-- Allow Notifications Button -->
    <Button
        android:id="@+id/btnAllowNotifications"
        android:layout_width="250dp"
        android:layout_height="wrap_content"
        android:text="Allow Notifications"
        android:layout_marginBottom="20dp" />

    <!-- Join Existing Group Button -->
    <Button
        android:id="@+id/btnJoinGroup"
        android:layout_width="250dp"
        android:layout_height="wrap_content"
        android:text="Join Existing Group"
        android:layout_marginBottom="20dp" />

    <!-- Create Family Group Button -->
    <Button
        android:id="@+id/btnCreateGroup"
        android:layout_width="250dp"
        android:layout_height="wrap_content"
        android:text="Create Family Group" />

</LinearLayout>
